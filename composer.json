{
  "name": "splitstack/laravel-nudge",
  "description": "Give Laravel notifications a lifecycle — they resolve themselves when their expected action is executed.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/contracts": "^11.0|^12.0|^13.0",
    "illuminate/database": "^11.0|^12.0|^13.0",
    "illuminate/events": "^11.0|^12.0|^13.0",
    "illuminate/notifications": "^11.0|^12.0|^13.0",
    "illuminate/support": "^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "pestphp/pest": "^3.8",
    "pestphp/pest-plugin-drift": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0"
  },
  "scripts": {
    "test": "php vendor/bin/pest"
  },
  "autoload": {
    "psr-4": {
      "Splitstack\\Nudge\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Splitstack\\Nudge\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Splitstack\\Nudge\\NudgeServiceProvider"
      ]
    }
  },
  "suggest": {
    "spatie/laravel-multitenancy": "Required if your app uses multiple tenants and notifications need to be scoped per tenant."
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
